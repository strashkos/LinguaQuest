<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(LinguaQuest.Web.Components.Layout.MainLayout)">
            <NotAuthorized>
                <LayoutView Layout="typeof(LinguaQuest.Web.Components.Layout.MainLayout)">
                    <div class="page-card">
                        <h1>Sign in required</h1>
                        <p>You need an account to open this page.</p>
                        <a class="primary-button" href="/login">Go to login</a>
                    </div>
                </LayoutView>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(LinguaQuest.Web.Components.Layout.MainLayout)">
            <div class="page-card">
                <h1>Page not found</h1>
                <p>The page you requested does not exist.</p>
            </div>
        </LayoutView>
    </NotFound>
</Router>