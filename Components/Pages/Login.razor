@attribute [AllowAnonymous]
@page "/login"

<section class="auth-page-shell">
    <div class="auth-visual">
        <div class="page-card glass-card">
            <p class="eyebrow">LinguaQuest</p>
            <h1>Повернись до свого прогресу.</h1>
            <p class="lead">Продовжуй збережений шлях і тримай вивчені слова прив’язаними до акаунта.</p>
        </div>

        <div class="glass-grid">
            <div class="page-card glass-card">
                <p class="eyebrow">Швидко</p>
                <strong>Миттєвий вхід</strong>
                <p class="muted">Одна форма без зайвого шуму.</p>
            </div>
            <div class="page-card glass-card">
                <p class="eyebrow">Збереження</p>
                <strong>Прогрес іде з тобою</strong>
                <p class="muted">Слова та налаштування зберігаються у профілі.</p>
            </div>
        </div>
    </div>

    <div class="page-card glass-card auth-form-panel">
        <p class="eyebrow">Вхід</p>
        <h1>Продовжити навчання</h1>
        <p class="muted"><a href="/register">Створи новий акаунт</a> або використай модалку входу в хедері.</p>

        <form class="auth-form" method="post" action="/auth/login">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <label>
                Логін або email
                <input class="search-input" name="UserNameOrEmail" autocomplete="username" />
            </label>

            <label>
                Пароль
                <input class="search-input" type="password" name="Password" autocomplete="current-password" />
            </label>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <p class="status-text">@Error</p>
            }

            <button class="primary-button wide-button" type="submit">Увійти</button>
        </form>
    </div>
</section>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
}