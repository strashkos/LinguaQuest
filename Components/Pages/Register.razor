@attribute [AllowAnonymous]
@page "/register"

<section class="auth-page-shell">
    <div class="auth-visual">
        <div class="page-card glass-card">
            <p class="eyebrow">LinguaQuest</p>
            <h1>Створи свій профіль.</h1>
            <p class="lead">Обери мову та стартовий рівень, щоб гра відразу відчувалась твоєю.</p>
        </div>

        <div class="glass-grid">
            <div class="page-card glass-card">
                <p class="eyebrow">Персонально</p>
                <strong>Вибери свій шлях</strong>
                <p class="muted">Одразу задай мову та рівень.</p>
            </div>
            <div class="page-card glass-card">
                <p class="eyebrow">Чисто</p>
                <strong>Без зайвого онбордингу</strong>
                <p class="muted">Швидка реєстрація і зрозумілі поля.</p>
            </div>
        </div>
    </div>

    <div class="page-card glass-card auth-form-panel">
        <p class="eyebrow">Реєстрація</p>
        <h1>Почни навчання</h1>
        <p class="muted"><a href="/login">Уже маєш акаунт?</a> або скористайся модалкою в хедері.</p>

        <form class="auth-form" method="post" action="/auth/register">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <label>
                Логін
                <input class="search-input" name="UserName" autocomplete="username" />
            </label>

            <label>
                Ім’я для відображення
                <input class="search-input" name="DisplayName" autocomplete="name" />
            </label>

            <label>
                Email
                <input class="search-input" type="email" name="Email" autocomplete="email" />
            </label>

            <div class="auth-grid-2">
                <label>
                    Пароль
                    <input class="search-input" type="password" name="Password" autocomplete="new-password" />
                </label>

                <label>
                    Підтверди пароль
                    <input class="search-input" type="password" name="ConfirmPassword" autocomplete="new-password" />
                </label>
            </div>

            <div class="auth-grid-2">
                <label>
                    Цільова мова
                    <select class="search-input" name="TargetLanguage">
                        <option value="@LearningLanguage.English">Англійська</option>
                        <option value="@LearningLanguage.German">Німецька</option>
                    </select>
                </label>

                <label>
                    Рівень
                    <select class="search-input" name="Level">
                        @foreach (var item in Enum.GetValues<LearningLevel>())
                        {
                            <option value="@item">@LearningLevelLabels.GetLabel(item)</option>
                        }
                    </select>
                </label>
            </div>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <p class="status-text">@Error</p>
            }

            <button class="primary-button wide-button" type="submit">Створити акаунт</button>
        </form>
    </div>
</section>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

}