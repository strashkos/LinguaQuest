@attribute [Authorize]
@page "/game/play"
@inject IGameService GameService
@inject IProgressService ProgressService
@inject IUserLearningSettingsService SettingsService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager Navigation
@inject IGameTimer Timer
@inject IJSRuntime JS

<div class="game-layout">
	<aside class="game-sidebar">
		<div class="page-card cabinet-card">
			<h3 class="cabinet-title">🎮 Мовна Гра</h3>
			<button type="button" class="ghost-button wide-button" @onclick="ExitToOverview">↩️ До огляду</button>

			<div class="cabinet-stats">
				<div class="stat-item">
					<div class="stat-value">@LearnedWordsCount</div>
					<div class="stat-label">Вивчено</div>
				</div>
				<div class="stat-item">
					<div class="stat-value">@AccuracyText</div>
					<div class="stat-label">Точність</div>
				</div>
			</div>

			<div class="cabinet-section">
				<p class="cabinet-subtitle">📚 НАЛАШТУВАННЯ</p>
				<p class="cabinet-text">Мова: <strong>@GetLanguageLabel(Settings?.TargetLanguage ?? LearningLanguage.English)</strong></p>
			</div>

			<div class="cabinet-section">
				<p class="cabinet-subtitle">🎯 СКЛАДНІСТЬ</p>
				<p class="cabinet-text">Рівень акаунта застосовується автоматично в грі.</p>
			</div>

			<div class="cabinet-section">
				<p class="cabinet-subtitle">📝 НОТАТКИ</p>
				<textarea class="notes-input" @bind="LevelNotes" placeholder="Напишіть нотатки..."></textarea>
			</div>

			<div class="cabinet-section">
				<p class="cabinet-subtitle">⚙️ ТЕМА</p>
				<p class="cabinet-text">Тема керується одним глобальним перемикачем у шапці.</p>
			</div>
			@if (GameState == "menu" || GameState == "results")
			{
				<button class="primary-button wide-button" @onclick="PlayButtonClick" disabled="@IsLoading">
					@if (IsLoading)
					{
						<span>⏳ Завантажуємо...</span>
					}
					else
					{
						<span>▶️ ГРАТИ</span>
					}
				</button>
			}
			else
			{
				<button class="ghost-button wide-button" @onclick="ExitToOverview">↩️ Меню</button>
			}
		</div>
	</aside>

	<div id="auth-modal" class="auth-modal hidden" role="dialog" aria-modal="true">
		<div class="auth-backdrop" onclick="hideAuthModal()"></div>
		<div class="auth-content page-card">
			<h3>🔐 Увійти або грати як гість</h3>
			<p>Щоб зберігати прогрес — увійдіть або зареєструйтесь. Можна також грати як гість без збереження.</p>
			<div class="auth-actions">
				<a class="primary-button" href="/login">Увійти</a>
				<a class="ghost-button" href="/register">Реєстрація</a>
				<button class="secondary-button" @onclick="StartGuestPlay">Грати як гість</button>
			</div>
		</div>
	</div>

	<main class="game-main">
		@if (GameState == "menu")
		{
			<div class="page-card level-path-card">
				<div class="menu-string" aria-label="Breadcrumb navigation">
					@if (UserId == null)
					{
						<a class="menu-chip" href="/">Головна</a>
					}
					<span class="menu-separator">/</span>
					<a class="menu-chip active" href="/game">Гра</a>
				</div>
				<h3 class="level-path-title">🏆 Прогрес рівнів</h3>
				<div class="level-path">
					@for (int i = 1; i <= 15; i++)
					{
						var level = i;
						var stars = GetLevelStars(i);
						<div class="level-step @(level == AccountLevelNumber ? "current" : "") @(stars > 0 ? "completed" : "")">
							<div class="level-circle"><span class="level-num">@level</span></div>
							<div class="level-stars">
								@for (int s = 0; s < 3; s++)
								{
									<span class="star @(s < stars ? "filled" : "")">⭐</span>
								}
							</div>
						</div>
					}
				</div>
			</div>
		}
		else if (GameState == "playing" && CurrentTask != null)
		{
			<div class="page-card game-card">
				<div class="game-header">
					<div>
						<span class="game-mode">@GetModeLabel(CurrentTask.Mode)</span>
					</div>
					@if (UseTimer)
					{
						<div class="timer-display">
							<div class="timer-bar">
								<div class="timer-fill" style="width: @(Timer.TotalSeconds == 0 ? 0 : Timer.RemainingSeconds * 100 / Timer.TotalSeconds)%"></div>
							</div>
							<span class="timer-text">@Timer.RemainingSeconds / @Timer.TotalSeconds с</span>
						</div>
					}
				</div>

				<div class="game-prompt">
					<h2>@CurrentTask.Prompt</h2>
					<p class="hint-text">@CurrentTask.Hint</p>
				</div>

				@if (CurrentTask.Mode == GameModeType.SentenceCompose)
				{
					<div class="cabinet-section">
						<input class="search-input" @bind="TypedSentence" placeholder="Наприклад: I see a cat." disabled="@(GameResult != null)" />
						<button class="primary-button" @onclick="SubmitTypedAnswer" disabled="@(GameResult != null || string.IsNullOrWhiteSpace(TypedSentence))">Перевірити</button>
					</div>
				}
				else
				{
					<div class="answers-grid @(CurrentTask.Mode == GameModeType.QuickFind || CurrentTask.Mode == GameModeType.SentenceChoice ? "grid-2x2" : "grid-1x4")">
						@foreach (var option in CurrentTask.Options)
						{
							var isDisabled = GameResult != null;
							var buttonClass = string.Empty;

							if (GameResult != null)
							{
								if (option == CurrentTask.CorrectAnswer)
								{
									buttonClass = "correct";
								}
								else if (option == LastAnswer && option != CurrentTask.CorrectAnswer)
								{
									buttonClass = "wrong";
								}
							}

							if (CurrentTask.Mode == GameModeType.QuickFind || CurrentTask.Mode == GameModeType.SentenceChoice)
							{
								<button type="button" class="answer-card @buttonClass" @onclick="() => AnswerClick(option)" disabled="@isDisabled">
									<div class="answer-text">@option</div>
								</button>
							}
							else
							{
								<button type="button" class="answer-button @buttonClass" @onclick="() => AnswerClick(option)" disabled="@isDisabled">@option</button>
							}
						}
					</div>
				}

				@if (GameResult != null)
				{
					<div class="result-box @(GameResult.IsCorrect ? "is-correct" : "is-wrong")">
						<strong>@GameResult.Message</strong>
						<p>@GameResult.Explanation</p>
						<button class="primary-button" @onclick="NextRound">➡️ Далі</button>
					</div>
				}
			</div>
		}
		else if (GameState == "results")
		{
			<div class="page-card game-end-card">
				<h2 class="end-title">🎉 ЧУДОВО!</h2>
				<div class="end-stats">
					<div class="end-stat">
						<div class="end-value">@SessionScore</div>
						<div class="end-label">Очки</div>
					</div>
					<div class="end-stat">
						<div class="end-value">@SessionCorrect / @SessionTotal</div>
						<div class="end-label">Правильні</div>
					</div>
				</div>
				<div class="end-stars">
					@for (int i = 0; i < SessionStars; i++)
					{
						<span class="star-large">⭐</span>
					}
				</div>
				<div class="end-actions">
					<button class="primary-button" @onclick="PlayAgain">🔄 Знову</button>
					<button class="ghost-button" @onclick="ExitToOverview">🏠 Огляд</button>
				</div>
			</div>
		}
	</main>
</div>

@code {
	private string? UserId;
	private GameTaskViewModel? CurrentTask;
	private GameResultViewModel? GameResult;
	private string? LastAnswer;
	private string TypedSentence = string.Empty;
	private LearningSettingsViewModel? Settings;
	private string GameState = "menu";
	private string LevelNotes = string.Empty;
	private bool IsLoading = false;
	private bool UseTimer = true;
	private bool IsGuest = false;
	private int LearnedWordsCount = 0;
	private int CorrectAttemptsCount = 0;
	private int TotalAttemptsCount = 0;
	private int SessionScore = 0;
	private int SessionCorrect = 0;
	private int SessionTotal = 0;
	private int SessionStars = 0;
	private readonly Dictionary<int, int> LevelStarsDict = new();
	private CancellationTokenSource? _timerCts;

	private readonly Queue<int> RecentWordIds = new();
	private const int RecentWordLimit = 5;

	protected override async Task OnInitializedAsync()
	{
		UserId = await CurrentUserService.GetUserIdAsync();
		await ReloadSettings();
		await ReloadProgressAsync();
	}

	private async Task ReloadSettings()
	{
		try
		{
			var model = await SettingsService.GetAsync(UserId ?? string.Empty);
			Settings = LearningSettingsViewModel.FromModel(model);
		}
		catch
		{
		}
	}

	private async Task ReloadProgressAsync()
	{
		if (string.IsNullOrWhiteSpace(UserId) || UserId == "guest")
		{
			LearnedWordsCount = 0;
			CorrectAttemptsCount = 0;
			TotalAttemptsCount = 0;
			LevelStarsDict.Clear();
			return;
		}

		try
		{
			var progress = await ProgressService.GetProgressAsync(UserId);
			LearnedWordsCount = progress.Count(item => item.IsLearned);
			CorrectAttemptsCount = progress.Sum(item => item.CorrectAttempts);
			TotalAttemptsCount = progress.Sum(item => item.Attempts);

			LevelStarsDict.Clear();
			foreach (var level in Enum.GetValues<LearningLevel>())
			{
				var learnedCount = progress.Count(item => item.WordPair?.Level == level && item.IsLearned);
				LevelStarsDict[(int)level] = learnedCount >= 6 ? 3 : learnedCount >= 3 ? 2 : learnedCount >= 1 ? 1 : 0;
			}
		}
		catch
		{
			LearnedWordsCount = 0;
			CorrectAttemptsCount = 0;
			TotalAttemptsCount = 0;
			LevelStarsDict.Clear();
		}
	}

	private int AccountLevelNumber => (int)(Settings?.Level ?? LearningLevel.Level1) + 1;

	private async Task PlayButtonClick()
	{
		if (IsLoading)
		{
			return;
		}

		if (UserId == null && !IsGuest)
		{
			await JS.InvokeVoidAsync("showAuthModal");
			return;
		}

		await StartGameAsync();
	}

	private async Task StartGameAsync()
	{
		IsLoading = true;
		StateHasChanged();
		try
		{
			await Task.Delay(300);
			GameState = "playing";
			SessionScore = 0;
			SessionCorrect = 0;
			SessionTotal = 0;
			await NextRound();
		}
		finally
		{
			IsLoading = false;
			StateHasChanged();
		}
	}

	private async Task StartGuestPlay()
	{
		IsGuest = true;
		UserId = "guest";
		await JS.InvokeVoidAsync("hideAuthModal");
		await StartGameAsync();
	}

	private async Task NextRound()
	{
		_timerCts?.Cancel();
		_timerCts?.Dispose();
		_timerCts = new CancellationTokenSource();
		GameResult = null;
		LastAnswer = null;
		TypedSentence = string.Empty;
		SessionTotal++;

		try
		{
			var settings = await SettingsService.GetAsync(UserId ?? string.Empty);
			GameTaskViewModel? nextTask = null;
			for (var attempt = 0; attempt < 5; attempt++)
			{
				nextTask = await GameService.CreateTaskAsync(
					LearningLanguage.Ukrainian,
					settings.TargetLanguage,
					settings.Level);

				if (nextTask == null || !RecentWordIds.Contains(nextTask.WordPairId))
				{
					break;
				}
			}

			CurrentTask = nextTask;
			if (CurrentTask != null)
			{
				RecentWordIds.Enqueue(CurrentTask.WordPairId);
				while (RecentWordIds.Count > RecentWordLimit)
				{
					RecentWordIds.Dequeue();
				}
			}

			if (UseTimer && CurrentTask != null)
			{
				Timer.Start(30);
				_ = RunTimerAsync(_timerCts.Token);
			}

			await ReloadProgressAsync();
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error: {ex.Message}");
		}

		StateHasChanged();
	}

	private async Task AnswerClick(string answer)
	{
		if (CurrentTask == null || GameResult != null)
		{
			return;
		}

		LastAnswer = answer;
		try
		{
			GameResult = await GameService.EvaluateAsync(CurrentTask, answer);
			await ProgressService.RegisterAttemptAsync(UserId ?? string.Empty, CurrentTask.WordPairId, GameResult.IsCorrect);

			if (GameResult.IsCorrect)
			{
				SessionCorrect++;
				SessionScore += 50;
			}
			else
			{
				SessionScore = Math.Max(0, SessionScore - 10);
			}

			Timer.Stop();
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error: {ex.Message}");
		}

		await ReloadProgressAsync();
		StateHasChanged();
	}

	private async Task SubmitTypedAnswer()
	{
		var answer = TypedSentence.Trim();
		if (string.IsNullOrWhiteSpace(answer))
		{
			return;
		}

		await AnswerClick(answer);
	}

	private async Task RunTimerAsync(CancellationToken token)
	{
		try
		{
			while (!token.IsCancellationRequested && Timer.IsRunning)
			{
				await Task.Delay(1000, token);
				Timer.Tick();
				await InvokeAsync(StateHasChanged);

				if (Timer.RemainingSeconds <= 0 && GameResult == null)
				{
					GameResult = new GameResultViewModel
					{
						IsCorrect = false,
						Message = "⏰ Час вийшов!",
						Explanation = CurrentTask?.Explanation ?? string.Empty,
						CorrectAnswer = CurrentTask?.CorrectAnswer ?? string.Empty
					};

					await ProgressService.RegisterAttemptAsync(UserId ?? string.Empty, CurrentTask?.WordPairId ?? 0, false);
					await InvokeAsync(StateHasChanged);
				}
			}
		}
		catch
		{
		}
	}

	private void PlayAgain()
	{
		GameState = "playing";
		SessionScore = 0;
		SessionCorrect = 0;
		SessionTotal = 0;
		_ = NextRound();
	}

	private void ExitToOverview()
	{
		_timerCts?.Cancel();
		Navigation.NavigateTo("/game");
	}

	private int GetLevelStars(int level) => LevelStarsDict.TryGetValue(level, out var stars) ? stars : 0;

	private static string GetModeLabel(GameModeType mode) => mode switch
	{
		GameModeType.SentenceChoice => "Речення: вибір слова",
		GameModeType.SentenceCompose => "Речення: вільна відповідь",
		GameModeType.QuickFind => "Швидкий вибір",
		GameModeType.WordOnMind => "Пошук перекладу",
		_ => mode.ToString()
	};

	private static string GetLanguageLabel(LearningLanguage language) => language switch
	{
		LearningLanguage.Ukrainian => "Українська",
		LearningLanguage.English => "Англійська",
		LearningLanguage.German => "Німецька",
		_ => language.ToString()
	};

	private string AccuracyText => TotalAttemptsCount == 0 ? "0%" : $"{Math.Round(CorrectAttemptsCount * 100.0 / TotalAttemptsCount):0}%";

	public void Dispose()
	{
		_timerCts?.Cancel();
		_timerCts?.Dispose();
	}
}