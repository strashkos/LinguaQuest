@implements IDisposable
@attribute [Authorize]
@page "/game"
@inject IGameService GameService
@inject IProgressService ProgressService
@inject IUserLearningSettingsService SettingsService
@inject ICurrentUserService CurrentUserService
@inject IGameTimer Timer

<div class="game-layout">
	<!-- ЛІВ ПАНЕЛЬ: КАБІНЕТ -->
	<aside class="game-sidebar">
		<div class="page-card cabinet-card">
			<h3 class="cabinet-title">🎮 Мовна Гра</h3>
			<button type="button" class="theme-toggle" onclick="toggleTheme()" title="Переключити тему">
				<span>☀️</span>
			</button>
			
			
			<div class="cabinet-stats">
				<div class="stat-item">
					<div class="stat-value">@CurrentScore</div>
					<div class="stat-label">Очки</div>
				</div>
				<div class="stat-item">
					<div class="stat-value">@CurrentStreak</div>
					<div class="stat-label">Стрік</div>
				</div>
			</div>

			<div class="cabinet-section">
				<p class="cabinet-subtitle">📚 НАЛАШТУВАННЯ</p>
				<p class="cabinet-text">Мова: <strong>@(Settings?.TargetLanguage.ToString() ?? "English")</strong></p>
				<p class="cabinet-text">Рівень: <strong>@GetLevelLabel(Settings?.Level ?? LearningLevel.Level1)</strong></p>
			</div>

			<div class="cabinet-section">
				<p class="cabinet-subtitle">🎯 РІВЕНЬ</p>
				<div class="level-buttons">
					<button class="level-btn @(SelectedLevel == 1 ? "active" : "")" @onclick="() => SelectLevel(1)">
						1️⃣ Базовий
					</button>
					<button class="level-btn @(SelectedLevel == 2 ? "active" : "")" @onclick="() => SelectLevel(2)">
						2️⃣ Середній
					</button>
					<button class="level-btn @(SelectedLevel == 3 ? "active" : "")" @onclick="() => SelectLevel(3)">
						3️⃣ Високий
					</button>
					<button class="level-btn @(SelectedLevel == 4 ? "active" : "")" @onclick="() => SelectLevel(4)">
						4️⃣ Просунутий
					</button>
				</div>
			</div>

			<div class="cabinet-section">
				<p class="cabinet-subtitle">📝 НОТАТКИ</p>
				<textarea class="notes-input" @bind="LevelNotes" placeholder="Напишіть нотатки..."></textarea>
			</div>

			@if (GameState == "menu" || GameState == "results")
			{
				<button class="primary-button wide-button" @onclick="PlayButtonClick" disabled="@IsLoading">
					@if (IsLoading)
					{
						<span>⏳ Завантажуємо...</span>
					}
					else
					{
						<span>▶️ ГРАТИ</span>
					}
				</button>
			}
			else
			{
				<button class="ghost-button wide-button" @onclick="MenuButtonClick">
					↩️ МЕНЮ
				</button>
			}
		</div>
	</aside>

	<!-- ПРАВА ПАНЕЛЬ: ІГРОВЕ ПОЛЕ -->
	<main class="game-main">
		@if (GameState == "menu")
		{
			<div class="page-card level-path-card">
				<div class="menu-string" aria-label="Breadcrumb navigation">
					<button type="button" class="menu-chip">Home</button>
					<span class="menu-separator">/</span>
					<button type="button" class="menu-chip active">Game</button>
					<span class="menu-separator">/</span>
					<button type="button" class="menu-chip">Levels</button>
				</div>
				<h3 class="level-path-title">🏆 СТЕЖКА</h3>
				<div class="level-path">
					@for (int i = 1; i <= 4; i++)
					{
						var level = i;
						var stars = GetLevelStars(i);
						<button type="button" class="level-step @(level == SelectedLevel ? "current" : "") @(stars > 0 ? "completed" : "")" @onclick="() => SelectLevel(level)">
							<div class="level-circle">
								<span class="level-num">@level</span>
							</div>
							<div class="level-stars">
								@for (int s = 0; s < 3; s++)
								{
									<span class="star @(s < stars ? "filled" : "")">⭐</span>
								}
							</div>
						</button>
					}
				</div>
			</div>
		}
		else if (GameState == "playing" && CurrentTask != null)
		{
			<div class="page-card game-card">
				<div class="game-header">
					<div>
						<span class="game-mode">@CurrentTask.Mode.ToString()</span>
						<p class="game-level">Рівень @SelectedLevel</p>
					</div>
					@if (UseTimer)
					{
						<div class="timer-display">
							<div class="timer-bar">
								<div class="timer-fill" style="width: @(Timer.TotalSeconds == 0 ? 0 : Timer.RemainingSeconds * 100 / Timer.TotalSeconds)%"></div>
							</div>
							<span class="timer-text">@Timer.RemainingSeconds / @Timer.TotalSeconds с</span>
						</div>
					}
				</div>

				<div class="game-prompt">
					<h2>@CurrentTask.Prompt</h2>
					<p class="hint-text">@CurrentTask.Hint</p>
				</div>

				<div class="answers-grid @(CurrentTask.Mode == GameModeType.QuickFind ? "grid-2x2" : "grid-1x4")">
					@foreach (var option in CurrentTask.Options)
					{
						var isDisabled = GameResult != null;
						var buttonClass = "";
						
						if (GameResult != null)
						{
							if (option == CurrentTask.CorrectAnswer)
								buttonClass = "correct";
							else if (option == LastAnswer && option != CurrentTask.CorrectAnswer)
								buttonClass = "wrong";
						}

						if (CurrentTask.Mode == GameModeType.QuickFind)
						{
							<button type="button" 
									class="answer-card @buttonClass"
									@onclick="() => AnswerClick(option)"
									disabled="@isDisabled">
								<div class="answer-text">@option</div>
							</button>
						}
						else
						{
							<button type="button" 
									class="answer-button @buttonClass"
									@onclick="() => AnswerClick(option)"
									disabled="@isDisabled">
								@option
							</button>
						}
					}
				</div>

				@if (GameResult != null)
				{
					<div class="result-box @(GameResult.IsCorrect ? "is-correct" : "is-wrong")">
						<strong>@GameResult.Message</strong>
						<p>@GameResult.Explanation</p>
						<button class="primary-button" @onclick="NextRound">➡️ Далі</button>
					</div>
				}
			</div>
		}
		else if (GameState == "results")
		{
			<div class="page-card game-end-card">
				<h2 class="end-title">🎉 ЧУДОВО!</h2>
				<div class="end-stats">
					<div class="end-stat">
						<div class="end-value">@SessionScore</div>
						<div class="end-label">Очки</div>
					</div>
					<div class="end-stat">
						<div class="end-value">@SessionCorrect / @SessionTotal</div>
						<div class="end-label">Правильні</div>
					</div>
				</div>
				<div class="end-stars">
					@for (int i = 0; i < SessionStars; i++)
					{
						<span class="star-large">⭐</span>
					}
				</div>
				<div class="end-actions">
					<button class="primary-button" @onclick="PlayAgain">🔄 Знову</button>
					<button class="ghost-button" @onclick="MenuButtonClick">🏠 Меню</button>
				</div>
			</div>
		}
	</main>
</div>

@code {
	private string? UserId;
	private GameTaskViewModel? CurrentTask;
	private GameResultViewModel? GameResult;
	private string? LastAnswer;
	private LearningSettingsViewModel? Settings;

	// State
	private string GameState = "menu"; // menu, playing, results
	private int SelectedLevel = 1;
	private string LevelNotes = string.Empty;
	private bool IsLoading = false;
	private bool UseTimer = true;

	// Scores
	private int CurrentScore = 1250;
	private int CurrentStreak = 7;
	private int SessionScore = 0;
	private int SessionCorrect = 0;
	private int SessionTotal = 0;
	private int SessionStars = 0;
	private Dictionary<int, int> LevelStarsDict = new() { { 1, 3 }, { 2, 2 }, { 3, 1 }, { 4, 0 } };
	private CancellationTokenSource? _timerCts;

	protected override async Task OnInitializedAsync()
	{
		UserId = await CurrentUserService.GetUserIdAsync();
		await ReloadSettings();
	}

	private async Task ReloadSettings()
	{
		try
		{
			var model = await SettingsService.GetAsync(UserId ?? "");
			Settings = LearningSettingsViewModel.FromModel(model);
		}
		catch { }
	}

	private void SelectLevel(int level)
	{
		SelectedLevel = level;
		StateHasChanged();
	}

	private async Task PlayButtonClick()
	{
		if (IsLoading) return;
		IsLoading = true;
		StateHasChanged();
		try
		{
			await Task.Delay(300);
			GameState = "playing";
			SessionScore = 0;
			SessionCorrect = 0;
			SessionTotal = 0;
			await NextRound();
		}
		finally
		{
			IsLoading = false;
			StateHasChanged();
		}
	}

	private async Task NextRound()
	{
		_timerCts?.Cancel();
		_timerCts?.Dispose();
		_timerCts = new CancellationTokenSource();
		GameResult = null;
		LastAnswer = null;
		SessionTotal++;
		try
		{
			var settings = await SettingsService.GetAsync(UserId ?? "");
			CurrentTask = await GameService.CreateTaskAsync(
				LearningLanguage.Ukrainian,
				settings.TargetLanguage,
				settings.Level,
				GameModeType.QuickFind
			);
			if (UseTimer && CurrentTask != null)
			{
				Timer.Start(30);
				_ = RunTimerAsync(_timerCts.Token);
			}
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error: {ex.Message}");
		}
		StateHasChanged();
	}

	private async Task AnswerClick(string answer)
	{
		if (CurrentTask == null || GameResult != null) return;
		LastAnswer = answer;
		try
		{
			GameResult = await GameService.EvaluateAsync(CurrentTask, answer);
			await ProgressService.RegisterAttemptAsync(
				UserId ?? "",
				CurrentTask.WordPairId,
				GameResult.IsCorrect
			);
			if (GameResult.IsCorrect)
			{
				SessionCorrect++;
				SessionScore += 50;
				CurrentStreak++;
			}
			else
			{
				SessionScore = Math.Max(0, SessionScore - 10);
				CurrentStreak = 0;
			}
			Timer.Stop();
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error: {ex.Message}");
		}
		StateHasChanged();
	}

	private async Task RunTimerAsync(CancellationToken token)
	{
		try
		{
			while (!token.IsCancellationRequested && Timer.IsRunning)
			{
				await Task.Delay(1000, token);
				Timer.Tick();
				await InvokeAsync(StateHasChanged);
				if (Timer.RemainingSeconds <= 0 && GameResult == null)
				{
					GameResult = new GameResultViewModel
					{
						IsCorrect = false,
						Message = "⏰ Час вийшов!",
						Explanation = CurrentTask?.Explanation ?? "",
						CorrectAnswer = CurrentTask?.CorrectAnswer ?? ""
					};
					await ProgressService.RegisterAttemptAsync(UserId ?? "", CurrentTask?.WordPairId ?? 0, false);
					await InvokeAsync(StateHasChanged);
				}
			}
		}
		catch { }
	}

	private void PlayAgain()
	{
		GameState = "playing";
		SessionScore = 0;
		SessionCorrect = 0;
		SessionTotal = 0;
		_ = NextRound();
	}

	private void MenuButtonClick()
	{
		_timerCts?.Cancel();
		if (SessionTotal > 0)
		{
			GameState = "results";
			SessionStars = SessionCorrect >= SessionTotal - 1 ? 3 : SessionCorrect >= SessionTotal / 2 ? 2 : 1;
		}
		else
		{
			GameState = "menu";
		}
		StateHasChanged();
	}

	private int GetLevelStars(int level) => LevelStarsDict.TryGetValue(level, out var s) ? s : 0;

	private string GetLevelLabel(LearningLevel level) => level switch
	{
		LearningLevel.Level1 => "Базовий",
		LearningLevel.Level2 => "Середній",
		LearningLevel.Level3 => "Високий",
		LearningLevel.Level4 => "Просунутий",
		_ => "–"
	};

	public void Dispose()
	{
		_timerCts?.Cancel();
		_timerCts?.Dispose();
	}
}
